{
	{$CADDY_GLOBAL_OPTIONS}

	frankenphp {
		{$FRANKENPHP_CONFIG}
	}
}

{$CADDY_EXTRA_CONFIG}

# Always-on loopback site: health probes and behind-proxy upstreams hit
# :8000 in EVERY mode — the public site's TLS story never affects whether
# the container can prove it is alive.
:8000 {
	root * /app/apps/server/public
	encode zstd br gzip

	@reverb path /app /app/* /apps/*
	handle @reverb {
		reverse_proxy {$WAYFINDR_REVERB_UPSTREAM:reverb:8080}
	}

	php_server
}

# SERVER_NAME is the TLS knob: a real hostname gets automatic HTTPS from
# Let's Encrypt; the ":80" default serves plain HTTP.
{$SERVER_NAME::80} {
	log {
		format json
	}

	root * /app/apps/server/public
	encode zstd br gzip

	# Reverb websockets share the public hostname so a single domain (and a
	# single certificate) covers the app AND realtime. The pusher protocol
	# lives under /app (client websocket) and /apps (server API).
	@reverb path /app /app/* /apps/*
	handle @reverb {
		reverse_proxy {$WAYFINDR_REVERB_UPSTREAM:reverb:8080}
	}

	{$CADDY_SERVER_EXTRA_DIRECTIVES}

	php_server
}
