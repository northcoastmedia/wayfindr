# The environment shape for the official self-hosting stack. Prefer
# scripts/self-host/generate-env.sh, which fills this in with fresh secrets
# and picks the right TLS mode; this file documents what it produces.
#
# This example shows AUTOMATIC HTTPS (FrankenPHP obtains certificates for
# SERVER_NAME and publishes 80/443). For an operator-managed proxy, set
# SERVER_NAME=:80, move the public binds to loopback ports
# (e.g. 127.0.0.1:18080 / 127.0.0.1:18443), set TRUSTED_PROXIES=*, and point
# the proxy at 127.0.0.1:8000.

WAYFINDR_IMAGE=ghcr.io/adamgreenwell/wayfindr:latest
WAYFINDR_ENV_FILE=.env
SERVER_NAME=support.example.com
WAYFINDR_PUBLIC_HTTP_BIND=80
WAYFINDR_PUBLIC_HTTPS_BIND=443
WAYFINDR_LOCAL_BIND=127.0.0.1:8000
WAYFINDR_PHP_VERSION=8.4
WAYFINDR_NODE_VERSION=24

APP_NAME=Wayfindr
APP_ENV=production
APP_KEY=base64:replace-with-generated-key
APP_DEBUG=false
APP_URL=https://support.example.com
TRUSTED_PROXIES=
# WAYFINDR_VERSION / WAYFINDR_COMMIT come baked into the official image and
# appear on /operator. Uncommenting them here OVERRIDES the image values —
# useful only for custom builds.
# WAYFINDR_VERSION=
# WAYFINDR_COMMIT=

DB_DATABASE=wayfindr
DB_USERNAME=wayfindr
DB_PASSWORD=replace-with-database-password

POSTGRES_DB=wayfindr
POSTGRES_USER=wayfindr
POSTGRES_PASSWORD=replace-with-database-password

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=wayfindr-production
REVERB_APP_KEY=replace-with-public-reverb-key
REVERB_APP_SECRET=replace-with-private-reverb-secret
# Public values; the compose stack overrides the server-side REVERB_* to the
# internal reverb service and passes these through to browsers.
REVERB_HOST=support.example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_CLIENT_HOST=support.example.com
REVERB_CLIENT_PORT=443
REVERB_CLIENT_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=

MAIL_MAILER=smtp
MAIL_HOST=replace-with-mail-host
MAIL_PORT=587
MAIL_USERNAME=replace-with-mail-user
MAIL_PASSWORD=replace-with-mail-password
MAIL_SCHEME=
MAIL_FROM_ADDRESS=support@example.com
MAIL_FROM_NAME="${APP_NAME}"
